# Single env file for: local backend, Vite dev server, Docker Compose, and frontend production builds.
# Copy to deploy/.env and set secrets. (File is gitignored.)

# --- LLM (https://openrouter.ai/keys) ---
OPENROUTER_API_KEY=
OPENAI_API_KEY=
# Base URL only: https://openrouter.ai/api/v1 — the OpenAI SDK POSTs to .../v1/chat/completions (same as OpenRouter docs).
# Wrong URLs: do not use /api without /v1, and do not set base to .../chat/completions (use base only; we strip /chat/completions if pasted).
# HTTP 500 from OpenRouter is usually upstream/model outage, not a wrong path (wrong path tends to be 404). Try VISION_MODEL=openai/gpt-4o-mini or check openrouter.ai status.
# LLM_BASE_URL=
# OPENROUTER_URL=

# OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Fashion Inspiration Library

# VISION_MODEL=
# EMBEDDING_MODEL=

# --- httpx (OpenAI SDK) — if you see SSLV3_ALERT_BAD_RECORD_MAC or connection errors on Windows ---
# HTTPX_TRUST_ENV=0
# HTTPX_NO_KEEPALIVE=1
# EVAL_IMPORT_DELAY_SEC=1.5
# Docker: small delay between seed imports (default 0.35 in docker-compose) reduces OpenRouter bursts.

# Docker backend entrypoint: set to 1 to skip eval/test_images seed on container start.
# SKIP_DB_SEED=0

# --- Backend API ---
# Comma-separated browser origins (include Vite :5173 and/or Docker UI :8080)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,http://localhost:8000

API_HOST=0.0.0.0
API_PORT=8000
MAX_UPLOAD_BYTES=20971520

# Relative to app/backend/ when running locally; Docker Compose overrides with /data/...
UPLOAD_DIR=uploads
DATA_DIR=data
# DATABASE_URL=

# --- Frontend (Vite; only VITE_* are exposed to the browser) ---
# Empty = same-origin /api (dev proxy or nginx in Docker)
VITE_API_BASE_URL=
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
VITE_DEV_PORT=5173
